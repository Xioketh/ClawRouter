// saas-backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  // Keep this if you specifically need the custom output path, otherwise you can remove it
  output   = "../src/generated/prisma" 
}

datasource db {
  provider = "postgresql"
  // The 'url' property is intentionally removed for Prisma 7 compatibility
}

// Tracks the Telegram users interacting with the bot
model TelegramUser {
  id        String   @id @default(uuid())
  chatId    String   @unique // The Telegram Chat ID
  username  String?
  state     String   @default("IDLE") // Tracks conversation state (e.g., QUALIFYING_LEAD, SUPPORT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// The actual Lead data extracted by the AI Agent
model Lead {
  id          String   @id @default(uuid())
  email       String   @unique
  companySize String?
  useCase     String?
  status      String   @default("NEW") // NEW, CONTACTED, DISQUALIFIED
  source      String   @default("TELEGRAM_BOT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}